# Express Server Port
PORT=8080

# Environment Mode
NODE_ENV=development

# Allowed Frontend Origin for CORS (Production)
FRONTEND_ORIGIN=https://traveller-saanga-367344494806.us-central1.run.app

# ── Firebase ──────────────────────────────────────────────────────────────────
# Option A (Production / Cloud Run): Uses Application Default Credentials (ADC)
# No extra config needed when deployed on Cloud Run with the right IAM roles.

# Option B (Local development): Path to a Firebase service account JSON key file
# Download from Firebase Console > Project Settings > Service Accounts > Generate new private key
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option C (Cloud Run secret env var): Paste the entire JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Maps / Places API (optional — routing uses free OSRM by default) ──
# GOOGLE_PLACES_API_KEY=your_google_maps_server_key
# GOOGLE_DIRECTIONS_API_KEY=your_google_directions_server_key

# ── Google Cloud Storage (for holiday & places cache) ─────────────────────────
# GCS_BUCKET_NAME=your-gcs-bucket-name
# GCP_PROJECT_ID=your-gcp-project-id
